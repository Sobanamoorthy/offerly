# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/bluecollar
# Or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bluecollar

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRE=7d

# Email Service (Optional - for email notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@bluecollar.com

# SMS Service (Optional - for OTP delivery via SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Communication & Call Routing
PLATFORM_PHONE_NUMBER=+1234567890
BACKEND_URL=http://localhost:5000
# Or in production:
# BACKEND_URL=https://api.bluecollar.com

# Telephony Provider (Choose one or leave blank for simulation mode)
# Option 1: Twilio (Recommended)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Option 2: Exotel
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_SID=your_exotel_sid

# Communication Settings
COMMUNICATION_PROVIDER=twilio
# Valid values: 'twilio', 'exotel', 'simulation' (simulation is default if not set or provider not configured)

OTP_EXPIRATION_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_MINUTES=15

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# Or in production:
# FRONTEND_URL=https://bluecollar.com

# Optional: Logging
LOG_LEVEL=debug
# Valid values: 'debug', 'info', 'warn', 'error'

# Session Configuration (if using sessions instead of JWT)
SESSION_SECRET=your_session_secret_key_here
COOKIE_MAX_AGE=86400000

# Payment Gateway (if implemented)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# Admin Settings
ADMIN_COMMISSION_PERCENTAGE=5
ADMIN_EMAIL=admin@bluecollar.com
